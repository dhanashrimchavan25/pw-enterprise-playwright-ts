# Set ENV=dev | qa | staging | prod (defaults to qa)
ENV=qa

# SauceDemo (demo application under test)
SAUCEDEMO_BASE_URL=https://www.saucedemo.com
SAUCEDEMO_STANDARD_USER=standard_user
SAUCEDEMO_LOCKED_OUT_USER=locked_out_user
SAUCEDEMO_PASSWORD=secret_sauce

# Auth state reuse (Step 2 — global setup will write this file)
STORAGE_STATE_PATH=storage/auth.json

# Logging
LOG_LEVEL=info
VERBOSE_LOGGING=false

# Reporting: playwright | allure | executive | all  (default: playwright)
REPORT_TYPE=playwright
